# ---------------------------------------------------------------
# Job Application Environment — inference configuration
# Copy this file to .env and fill in your values.
# Load with: $env vars or `python-dotenv` / your shell's source.
# ---------------------------------------------------------------

# URL of your running FastAPI environment server
API_BASE_URL=http://localhost:8000

# OpenAI-compatible LLM endpoint
# HF Inference Router:
OPENAI_BASE_URL=https://router.huggingface.co/v1
# Local Ollama (uncomment to use):
# OPENAI_BASE_URL=http://localhost:11434/v1
# Local LM Studio (uncomment to use):
# OPENAI_BASE_URL=http://localhost:1234/v1

# Model name passed to the LLM endpoint
# HF Router example:
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
# Local example (uncomment to use):
# MODEL_NAME=qwen2.5:72b

# Your HuggingFace token — required for remote inference, NO default intentionally
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# Optional — used for logging only, does not affect runtime behaviour
# LOCAL_IMAGE_NAME=job-app-env:latest